PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/vendor-routing-platform
CLIENT_URL=http://localhost:5173

# Vendors whose currentLatency exceeds this (ms) are excluded from routing
LATENCY_THRESHOLD_MS=2000

# Fallback timeout (ms) used when a vendor does not define its own
DEFAULT_TIMEOUT_MS=3000

# Simulated vendor outcome probabilities (relative weights, normalized internally)
SIM_SUCCESS_RATE=70
SIM_FAILURE_RATE=20
SIM_TIMEOUT_RATE=10

# Rate-limit window size (ms)
RATE_LIMIT_WINDOW_MS=60000

# A vendor is auto-marked unhealthy once its rolling error rate exceeds this
# percentage, but only after it has handled at least MIN_SAMPLE_SIZE_FOR_HEALTH_CHECK requests
HIGH_ERROR_RATE_THRESHOLD=50
MIN_SAMPLE_SIZE_FOR_HEALTH_CHECK=5

# How long (ms) the vendor list is cached before /route re-queries MongoDB
VENDOR_CACHE_TTL_MS=3000
